---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { withBase } from '../../config/site';

export async function getStaticPaths() {
  const bios = await getCollection('biografias');
  return bios.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const name = d.name || entry.id.split(/[-_]/).map((w) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
if (!d.name) console.warn(`\n⚠️  Biografia "${entry.id}" sem 'name' — usando "${name}".\n`);
const banner = withBase(d.image ?? `/biografias/${entry.id}.webp`);
const fallback = withBase('/biografias/default.webp');
const feastValid = !!d.feast && /^\d{2}-\d{2}$/.test(d.feast);
const feastDM = feastValid ? `${d.feast!.slice(3, 5)}/${d.feast!.slice(0, 2)}` : '';

const prayers = await getCollection('prayers');
const pmap = new Map(prayers.map((p) => [p.id, p.data.title]));
const _norm = (x: string) => (x ?? '').normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim();
const _bn = _norm(d.name ?? name);
const _auto = prayers.filter((p) => {
  if (d.feast && p.data.liturgicalFeast === d.feast) return true;
  const ps = _norm(p.data.saint ?? '');
  return !!ps && !!_bn && (ps.includes(_bn) || _bn.includes(ps));
}).map((p) => p.id);
const _allSlugs = [...new Set([...(d.relatedPrayers ?? []), ..._auto])];
const related = _allSlugs
  .map((s) => ({ slug: s, title: pmap.get(s) }))
  .filter((r) => r.title); // orações inexistentes são ignoradas (não quebra o build)
const missingRel = (d.relatedPrayers ?? []).filter((s) => !pmap.has(s));
if (missingRel.length) console.warn(`\n⚠️  Biografia "${entry.id}": orações relacionadas inexistentes, ignoradas: ${missingRel.join(', ')}\n`);
---
<Base title={name}>
  <article>
    <header class="reader-hero">
      <img class="reader-bg-blur" src={banner} alt="" aria-hidden="true" data-parallax data-speed="0.1" onerror="this.style.display='none'" />
      <img class="reader-bg" src={banner} alt={name} width="1600" height="1000" onerror={`this.onerror=null;this.src='${fallback}'`} />
      <div class="reader-shade"></div>
      <div class="reader-head">
        {d.title && <p class="reader-type">{d.title}</p>}
        <h1 class="reader-title">{name}</h1>
        {(d.born || d.died) && <p class="reader-saint">{[d.born, d.died].filter(Boolean).join(' — ')}</p>}
      </div>
    </header>

    <div class="reader-body">
      <div class="reader-tools" role="group" aria-label="Ferramentas">
        <button id="bioFavBtn" class="rtool" type="button" aria-pressed="false" data-slug={entry.id}>
          <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><path class="hpath" d="M12 21l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.18L12 21z" stroke-width="2"/></svg>
          <span data-i18n="fav_save">Salvar</span>
        </button>
        <button id="bioShareBtn" class="rtool" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><path d="M14 9V5l7 7-7 7v-4.1C9 11.8 5.5 13 3 16c1-5 4-9 11-9.9z" fill="currentColor"/></svg>
          <span data-i18n="share">Compartilhar</span>
        </button>
      </div>

      {(feastDM || d.patronage) && (
        <dl class="bio-facts">
          {feastDM && <div><dt data-i18n="bio_feast">Festa litúrgica</dt><dd>{feastDM}</dd></div>}
          {d.patronage && <div><dt data-i18n="bio_patron">Padroeiro de</dt><dd>{d.patronage}</dd></div>}
        </dl>
      )}

      {related.length > 0 && (
        <div class="bio-related">
          <h2 data-i18n="bio_related">Orações relacionadas</h2>
          <div class="bio-related-row">
            {related.map((r) => (
              <a class="btn" href={withBase(`/oracao/${r.slug}`)}>{r.title}</a>
            ))}
          </div>
        </div>
      )}

      <div class="prayer-body">
        <Content />
      </div>
    </div>
  </article>

  <script>
    (function () {
      const t = (window as any).odt || ((k: string) => k);
      const odFav = (window as any).odFavBio;
      const favBtn = document.getElementById('bioFavBtn');
      if (favBtn && odFav) {
        const slug = (favBtn as HTMLElement).dataset.slug;
        const setFav = () => {
          const on = odFav.has(slug);
          favBtn.setAttribute('aria-pressed', on ? 'true' : 'false');
          const lab = favBtn.querySelector('span');
          if (lab) lab.textContent = t(on ? 'fav_saved' : 'fav_save');
        };
        setFav();
        favBtn.addEventListener('click', () => { odFav.toggle(slug); setFav(); });
        document.addEventListener('od:lang', setFav);
      }
      const shareBtn = document.getElementById('bioShareBtn');
      if (shareBtn) {
        shareBtn.addEventListener('click', () => {
          const url = location.href.split('#')[0];
          const title = document.title;
          if ((navigator as any).share) { (navigator as any).share({ title, url }).catch(() => {}); return; }
          const fb = () => { const lab = shareBtn.querySelector('span'); if (lab) { lab.textContent = t('link_copied'); setTimeout(() => { lab.textContent = t('share'); }, 1800); } };
          if (navigator.clipboard && navigator.clipboard.writeText) navigator.clipboard.writeText(url).then(fb).catch(fb);
          else { try { const ta = document.createElement('textarea'); ta.value = url; ta.style.position = 'fixed'; ta.style.opacity = '0'; document.body.appendChild(ta); ta.focus(); ta.select(); document.execCommand('copy'); ta.remove(); fb(); } catch (e) {} }
        });
      }
    })();
  </script>

  <style>
    .bio-facts { display: flex; flex-wrap: wrap; gap: 1.4rem 2.4rem; margin: 0 0 1.8rem; padding: 0 0 1.4rem; border-bottom: 1px solid var(--hair); }
    .bio-facts dt { font-size: .7rem; letter-spacing: .14em; text-transform: uppercase; color: var(--ink-soft); margin-bottom: .15rem; }
    .bio-facts dd { margin: 0; font-family: 'Cormorant', serif; font-size: 1.2rem; color: var(--gold); }
    .bio-related { margin: 0 0 2rem; }
    .bio-related .btn { padding: .4rem .85rem; font-size: .88rem; border-radius: 9px; }
    .bio-related h2 { font-size: .8rem; letter-spacing: .16em; text-transform: uppercase; color: var(--gold); margin: 0 0 .8rem; }
    .bio-related-row { display: flex; flex-wrap: wrap; gap: .5rem; }
  </style>
</Base>
