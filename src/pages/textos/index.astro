---
import Base from '../../layouts/Base.astro';
import { withBase } from '../../config/site';
import { getCollection } from 'astro:content';
import fs from 'node:fs';

const entries = await getCollection('textos');
entries.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
const bg = fs.existsSync('public/textos/index.webp')
  ? withBase('/textos/index.webp')
  : withBase('/textures/rays.webp');
---
<Base title="Textos" description="Textos de formação e devoção do Oratório Digital — explicações sobre a fé, a liturgia e a vida cristã.">
  <section class="txs-hero">
    <div class="txs-bg" style={`background-image: url('${bg}')`} aria-hidden="true"></div>
    <div class="txs-shade" aria-hidden="true"></div>

    <div class="txs-wrap">
      <p class="txs-eyebrow" data-i18n="nav_textos">Textos</p>
      <h1 class="txs-title" data-i18n="textos_title">Textos</h1>
      <p class="txs-lead" data-i18n="textos_lead">Leituras para entender e viver melhor a fé — aos poucos, novos textos vão aparecendo aqui.</p>

      {entries.length === 0 ? (
        <p class="txs-empty">Em breve, novos textos.</p>
      ) : (
        <div class="txs-grid">
          {entries.map((e) => (
            <a class="txs-card" href={withBase(`/textos/${e.id}`)}>
              {e.data.icon && <span class="txs-card-icon" aria-hidden="true">{e.data.icon}</span>}
              <span class="txs-card-title">{e.data.title}</span>
              {e.data.summary && <span class="txs-card-summary">{e.data.summary}</span>}
              <span class="txs-card-more">Ler <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .txs-hero {
    position: relative; overflow: hidden;
    min-height: 100vh; display: flex; align-items: center;
    background: radial-gradient(120% 100% at 50% 0%, #2a1d0e 0%, #1a1208 55%, #120c06 100%);
  }
  .txs-bg { position: absolute; inset: 0; background-position: center; background-size: cover; background-repeat: no-repeat; background-attachment: fixed; }
  .txs-shade { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(8,5,2,.6) 0%, rgba(8,5,2,.5) 40%, rgba(8,5,2,.72) 100%); }

  .txs-wrap { position: relative; z-index: 1; width: 100%; max-width: var(--maxw); margin: 0 auto; padding: clamp(2.6rem, 7vw, 5rem) clamp(1rem, 4vw, 2.2rem); }

  .txs-eyebrow { color: var(--season, var(--gold)); font-size: .8rem; letter-spacing: .26em; text-transform: uppercase; margin: 0 0 .7rem; }
  .txs-title { font-family: 'Cormorant', serif; font-weight: 600; font-size: clamp(2.4rem, 7vw, 3.6rem); line-height: 1.05; color: #f5ecd8; margin: 0 0 .8rem; }
  .txs-lead { font-family: 'EB Garamond', serif; font-size: 1.12rem; line-height: 1.7; color: #d8c8a8; max-width: 36rem; margin: 0 0 2.4rem; }

  .txs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr)); gap: 1.1rem; }
  .txs-card {
    display: flex; flex-direction: column; align-items: flex-start;
    background: rgba(28, 26, 23, .82);
    -webkit-backdrop-filter: blur(10px); backdrop-filter: blur(10px);
    border: 1px solid rgba(200, 162, 74, .22); border-radius: 16px;
    padding: 1.5rem 1.4rem; text-decoration: none;
    box-shadow: 0 20px 50px rgba(0, 0, 0, .4);
    transition: border-color .2s, transform .2s, background .2s;
  }
  .txs-card:hover { border-color: var(--gold); transform: translateY(-3px); background: rgba(36, 32, 26, .9); }
  .txs-card-icon { font-size: 1.5rem; color: var(--gold); margin-bottom: .6rem; line-height: 1; }
  .txs-card-title { font-family: 'Cormorant', serif; font-size: 1.5rem; font-weight: 600; color: #f3e9d6; margin-bottom: .5rem; line-height: 1.15; }
  .txs-card-summary { font-family: 'EB Garamond', serif; font-size: 1rem; line-height: 1.6; color: #cdc0a8; margin-bottom: 1rem; }
  .txs-card-more { margin-top: auto; display: inline-flex; align-items: center; gap: .35rem; color: var(--gold-bright); font-size: .82rem; letter-spacing: .12em; text-transform: uppercase; }
  .txs-card:hover .txs-card-more { gap: .55rem; }

  .txs-empty { font-family: 'EB Garamond', serif; font-size: 1.1rem; color: #cdc0a8; }
</style>
