---
import fs from 'node:fs';
import { withBase } from '../config/site';
const { prayer } = Astro.props;
const { id, data } = prayer;

// usa a versão "_thumb" (menor) se existir; senão, a imagem normal
const hasThumb = fs.existsSync(`public/saints/${id}_thumb.webp`);
const img = withBase(hasThumb ? `/saints/${id}_thumb.webp` : `/saints/${id}.webp`);
const imgFallback = withBase('/saints/default.webp');

const href = withBase(`/oracao/${id}`);
const langCode = (data.language ?? 'pt-BR').slice(0, 2).toUpperCase();
const feast = data.liturgicalFeast ?? '';
const total = data.totalDays ?? 1;
const offset = data.novenaSuggestedStart ?? 0;
---
<a class="card" href={href}
   data-type={data.type}
   data-lang={data.language}
   data-feast={feast}
   data-total={total}
   data-offset={offset}
   data-search={`${data.title} ${data.saint ?? ''} ${data.tags.join(' ')} ${data.description}`.toLowerCase()}>
  <img class="card-img" src={img} alt={data.saint ?? data.title} loading="lazy" width="600" height="800" onerror={`this.onerror=null;this.src='${imgFallback}'`} />
  <div class="card-body">
    <span class="card-type" data-i18n={`type_${data.type}`}>{data.type}</span>
    <h3 class="card-title">{data.title}</h3>
    {data.saint && <span class="card-saint">{data.saint}</span>}
    {data.description && <p class="card-desc">{data.description}</p>}
    <div class="card-foot">
      <span class="pill">{langCode}</span>
      {data.type === 'novena' && data.totalDays && <span class="pill">{data.totalDays} dias</span>}
    </div>
  </div>
</a>
