---
// Votiva: o número de orações concluídas por toda a comunidade.
---
<div class="votive" id="community">
  <div class="candle" aria-hidden="true">
    <span class="candle-flame"></span>
    <span class="candle-wick"></span>
    <span class="candle-body"></span>
  </div>
  <div class="votive-join" data-i18n="community_pre">Esse site já guiou</div>
  <div class="votive-number" id="communityNumber" aria-live="polite">—</div>
  <div class="votive-label" data-i18n="community_post">orações, ajudando a iluminar nosso mundo.</div>
</div>
